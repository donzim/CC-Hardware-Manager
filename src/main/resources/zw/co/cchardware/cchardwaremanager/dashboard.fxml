<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="zw.co.cchardware.cchardwaremanager.DashboardController">

    <top>
        <Label text="CC HARDWARE MANAGER"
               style="-fx-font-size:24px;
                      -fx-font-weight:bold;
                      -fx-padding:20;"/>
    </top>

    <center>

        <VBox spacing="20" alignment="TOP_CENTER">

            <!-- Statistics Section -->
            <HBox spacing="20" alignment="CENTER">

                <VBox alignment="CENTER"
                      style="-fx-border-color: lightgray;
                         -fx-border-radius: 5;
                         -fx-padding: 15;
                         -fx-background-color: #f8f8f8;">

                    <Label text="📦 Total Products"/>
                    <Label fx:id="totalProductsLabel"
                           text="0"
                           style="-fx-font-size:22px; -fx-font-weight:bold;"/>

                </VBox>

                <VBox alignment="CENTER"
                      style="-fx-border-color: lightgray;
                         -fx-border-radius: 5;
                         -fx-padding: 15;
                         -fx-background-color: #f8f8f8;">

                    <Label text="📦 Stock Units"/>
                    <Label fx:id="totalStockLabel"
                           text="0"
                           style="-fx-font-size:22px; -fx-font-weight:bold;"/>

                </VBox>

                <VBox alignment="CENTER"
                      style="-fx-border-color: lightgray;
                         -fx-border-radius: 5;
                         -fx-padding: 15;
                         -fx-background-color: #f8f8f8;">

                    <Label text="⚠ Low Stock"/>
                    <Label fx:id="lowStockLabel"
                           text="0"
                           style="-fx-font-size:22px; -fx-font-weight:bold;"/>

                </VBox>

            </HBox>


            <HBox spacing="20" alignment="CENTER">

                <VBox alignment="CENTER"
                      style="-fx-border-color: lightgray;
                 -fx-border-radius: 5;
                 -fx-padding: 15;
                 -fx-background-color: #f8f8f8;">

                    <Label text="💰 Inventory Cost"/>
                    <Label fx:id="inventoryCostLabel"
                           text="\$0.00"
                           style="-fx-font-size:22px; -fx-font-weight:bold;"/>

                </VBox>

                <VBox alignment="CENTER"
                      style="-fx-border-color: lightgray;
                 -fx-border-radius: 5;
                 -fx-padding: 15;
                 -fx-background-color: #f8f8f8;">

                    <Label text="💵 Potential Sales"/>
                    <Label fx:id="potentialSalesLabel"
                           text="\$0.00"
                           style="-fx-font-size:22px; -fx-font-weight:bold;"/>

                </VBox>

            </HBox>

            <!-- Navigation -->
            <VBox spacing="15" alignment="CENTER">

                <Button text="🛒 New Sale" prefWidth="220"/>

                <Button text="📦 Inventory"
                        prefWidth="220"
                        onAction="#openInventory"/>

                <Button text="🧾 Quotations" prefWidth="220"/>

                <Button text="📄 Receipts" prefWidth="220"/>

                <Button text="📊 Reports" prefWidth="220"/>

                <Button text="⚙ Settings" prefWidth="220"/>

                <Button text="Logout" prefWidth="220"/>

            </VBox>

        </VBox>

    </center>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

</BorderPane>