<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="zw.co.cchardware.cchardwaremanager.DashboardController">

    <top>
        <Label text="CC HARDWARE MANAGER"
               style="-fx-font-size:24px;
                      -fx-font-weight:bold;
                      -fx-padding:20;"/>
    </top>

    <center>

        <VBox spacing="15" alignment="CENTER">

            <Button text="🛒 New Sale" prefWidth="220"/>

            <Button text="📦 Inventory" prefWidth="220" onAction="#openInventory"/>

            <Button text="🧾 Quotations" prefWidth="220"/>

            <Button text="📄 Receipts" prefWidth="220"/>

            <Button text="📊 Reports" prefWidth="220"/>

            <Button text="⚙ Settings" prefWidth="220"/>

            <Button text="Logout" prefWidth="220"/>

        </VBox>

    </center>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

</BorderPane>